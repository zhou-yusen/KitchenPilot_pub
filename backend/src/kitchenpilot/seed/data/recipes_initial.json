[
  {
    "id": 1,
    "name": "番茄炒蛋",
    "description": "酸甜开胃的新手家常菜，关键是鸡蛋先炒嫩、番茄炒出汁后再合炒。",
    "difficulty": "easy",
    "time_minutes": 15,
    "beginner_friendly": true,
    "cuisine": "家常菜",
    "seasons": [
      "spring",
      "summer",
      "autumn",
      "winter"
    ],
    "ingredients": [
      {
        "ingredient": "番茄",
        "amount": "2个",
        "required": true
      },
      {
        "ingredient": "鸡蛋",
        "amount": "3个",
        "required": true
      },
      {
        "ingredient": "小葱",
        "amount": "1根",
        "required": false
      },
      {
        "ingredient": "蒜",
        "amount": "1瓣",
        "required": false
      },
      {
        "ingredient": "食用油",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "盐",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "白糖",
        "amount": "少量",
        "required": false
      }
    ],
    "steps": [
      {
        "order": 1,
        "content": "番茄洗净后切成滚刀块，小葱切葱花。",
        "beginner_tip": "番茄选成熟偏软的更容易炒出汁。",
        "risk_tip": null
      },
      {
        "order": 2,
        "content": "鸡蛋打入碗中，加少量盐打散。",
        "beginner_tip": "蛋液打匀即可，不需要打出很多泡。",
        "risk_tip": null
      },
      {
        "order": 3,
        "content": "热锅倒油，倒入蛋液，炒到刚凝固成大块后盛出。",
        "beginner_tip": "鸡蛋不要炒到完全干硬，后面还会回锅。",
        "risk_tip": "倒蛋液前确认锅中没有明显水分，避免热油飞溅。"
      },
      {
        "order": 4,
        "content": "锅中补少量油，放入番茄翻炒到变软出汁。",
        "beginner_tip": "想要汤汁多，可以边炒边轻压番茄。",
        "risk_tip": null
      },
      {
        "order": 5,
        "content": "按番茄酸度加入少量糖，再加盐调味。",
        "beginner_tip": "糖只是平衡酸味，不要一次放太多。",
        "risk_tip": null
      },
      {
        "order": 6,
        "content": "倒回鸡蛋，快速翻炒到鸡蛋裹上番茄汁，撒葱花出锅。",
        "beginner_tip": "鸡蛋回锅后不要久炒，裹上番茄汁即可。",
        "risk_tip": null
      }
    ],
    "common_failures": [
      "鸡蛋炒老",
      "番茄不出汁",
      "糖放太多导致偏甜",
      "蛋块太碎影响口感"
    ],
    "substitutions": {
      "白糖": "可省略，或用少量番茄酱增强酸甜味。",
      "小葱": "可用香菜或不放。"
    },
    "safety_notes": [
      "鸡蛋要炒熟后食用。",
      "热油下锅前尽量沥干食材表面水分。"
    ],
    "source_urls": [
      "https://lanfanapp.com/recipe/2039/",
      "https://m.xiachufang.com/recipe/107620836/"
    ]
  },
  {
    "id": 2,
    "name": "可乐鸡翅",
    "description": "咸甜口鸡翅菜，适合入门练习煎制、焖煮和收汁。",
    "difficulty": "medium",
    "time_minutes": 40,
    "beginner_friendly": true,
    "cuisine": "家常菜",
    "seasons": [
      "spring",
      "summer",
      "autumn",
      "winter"
    ],
    "ingredients": [
      {
        "ingredient": "鸡翅中",
        "amount": "8-10个",
        "required": true
      },
      {
        "ingredient": "可乐",
        "amount": "1罐",
        "required": true
      },
      {
        "ingredient": "姜",
        "amount": "3片",
        "required": false
      },
      {
        "ingredient": "生抽",
        "amount": "1-2勺",
        "required": true
      },
      {
        "ingredient": "老抽",
        "amount": "少量",
        "required": false
      },
      {
        "ingredient": "料酒",
        "amount": "1勺",
        "required": false
      },
      {
        "ingredient": "盐",
        "amount": "少量",
        "required": false
      }
    ],
    "steps": [
      {
        "order": 1,
        "content": "鸡翅洗净，两面各划两刀。",
        "beginner_tip": "划刀能帮助入味，但不要切太深。",
        "risk_tip": "处理生鸡肉后要清洗刀具和砧板。"
      },
      {
        "order": 2,
        "content": "鸡翅冷水下锅，加入姜片和料酒，煮出浮沫后捞出。",
        "beginner_tip": "焯水可以降低腥味，也让新手更容易判断熟度。",
        "risk_tip": null
      },
      {
        "order": 3,
        "content": "把焯好的鸡翅擦干或沥干水分。",
        "beginner_tip": "表面越干，后面煎的时候越不容易溅油。",
        "risk_tip": "鸡翅表面水分多会溅油，入锅前要擦干。"
      },
      {
        "order": 4,
        "content": "锅中少油或不放油，将鸡翅煎到两面微黄。",
        "beginner_tip": "鸡皮面先下锅，更容易煎出香味。",
        "risk_tip": null
      },
      {
        "order": 5,
        "content": "加入可乐、生抽、少量老抽和姜片，煮开。",
        "beginner_tip": "老抽主要负责上色，少量即可。",
        "risk_tip": null
      },
      {
        "order": 6,
        "content": "转小火焖煮到鸡翅熟透，中途翻面一次。",
        "beginner_tip": "可乐不要一次收得太干，中途观察汤汁。",
        "risk_tip": "鸡肉必须完全熟透后食用。"
      },
      {
        "order": 7,
        "content": "开大火收汁，汤汁浓稠并能挂在鸡翅表面时出锅。",
        "beginner_tip": "收汁阶段要勤翻动，避免糖分糊锅。",
        "risk_tip": null
      }
    ],
    "common_failures": [
      "鸡翅内部不熟",
      "收汁糊锅",
      "味道过甜",
      "颜色太深发苦"
    ],
    "substitutions": {
      "老抽": "可省略，颜色会浅一些。",
      "可乐": "可用无糖可乐，但甜味和收汁效果会变化。"
    },
    "safety_notes": [
      "鸡翅属于禽肉，必须充分加热。",
      "生熟砧板和夹子尽量分开。"
    ],
    "source_urls": [
      "https://lanfanapp.com/recipe/281",
      "https://www.xiachufang.com/recipe/1000229/"
    ]
  },
  {
    "id": 3,
    "name": "蛋炒饭",
    "description": "利用剩米饭制作的快手主食，重点是米饭干爽、蛋香明显、火候足。",
    "difficulty": "easy",
    "time_minutes": 15,
    "beginner_friendly": true,
    "cuisine": "家常菜",
    "seasons": [
      "spring",
      "summer",
      "autumn",
      "winter"
    ],
    "ingredients": [
      {
        "ingredient": "隔夜米饭",
        "amount": "1碗",
        "required": true
      },
      {
        "ingredient": "鸡蛋",
        "amount": "2个",
        "required": true
      },
      {
        "ingredient": "小葱",
        "amount": "1根",
        "required": false
      },
      {
        "ingredient": "胡萝卜丁",
        "amount": "少量",
        "required": false
      },
      {
        "ingredient": "火腿丁",
        "amount": "少量",
        "required": false
      },
      {
        "ingredient": "盐",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "食用油",
        "amount": "适量",
        "required": true
      }
    ],
    "steps": [
      {
        "order": 1,
        "content": "把米饭提前打散，明显结块的地方用勺子压开。",
        "beginner_tip": "冷藏过的米饭更容易炒散。",
        "risk_tip": "剩饭需充分加热后食用。"
      },
      {
        "order": 2,
        "content": "鸡蛋打散，小葱切葱花，胡萝卜、火腿等配菜切小丁。",
        "beginner_tip": "配菜尽量切小，熟得快也更容易拌匀。",
        "risk_tip": null
      },
      {
        "order": 3,
        "content": "热锅倒油，先炒鸡蛋到刚凝固，盛出备用。",
        "beginner_tip": "想要蛋香明显，可以先炒蛋再炒饭。",
        "risk_tip": null
      },
      {
        "order": 4,
        "content": "锅中补少量油，下配菜丁炒到断生。",
        "beginner_tip": "如果配菜已经是熟的，这一步可以缩短。",
        "risk_tip": null
      },
      {
        "order": 5,
        "content": "下米饭翻炒，把饭粒尽量炒散。",
        "beginner_tip": "不要急着调味，先把饭炒松散。",
        "risk_tip": null
      },
      {
        "order": 6,
        "content": "倒回鸡蛋，加盐调味，撒葱花后翻炒均匀出锅。",
        "beginner_tip": "酱油可少量使用，避免饭变湿发粘。",
        "risk_tip": null
      }
    ],
    "common_failures": [
      "米饭结块",
      "饭太湿发粘",
      "鸡蛋炒老",
      "调味不均匀"
    ],
    "substitutions": {
      "隔夜米饭": "可用新米饭摊开放凉后再炒。",
      "火腿丁": "可用虾仁、玉米粒或不放。"
    },
    "safety_notes": [
      "剩米饭应冷藏保存，炒制时彻底加热。"
    ],
    "source_urls": [
      "https://cook.aiursoft.cn/",
      "https://www.xiachufang.com/"
    ]
  },
  {
    "id": 4,
    "name": "热汤面",
    "description": "适合早餐或夜宵的快手面食，核心是先调好汤底，再煮面和配菜。",
    "difficulty": "easy",
    "time_minutes": 15,
    "beginner_friendly": true,
    "cuisine": "家常菜",
    "seasons": [
      "spring",
      "summer",
      "autumn",
      "winter"
    ],
    "ingredients": [
      {
        "ingredient": "面条",
        "amount": "1人份",
        "required": true
      },
      {
        "ingredient": "鸡蛋",
        "amount": "1个",
        "required": false
      },
      {
        "ingredient": "青菜",
        "amount": "几棵",
        "required": false
      },
      {
        "ingredient": "小葱",
        "amount": "1根",
        "required": false
      },
      {
        "ingredient": "生抽",
        "amount": "1勺",
        "required": true
      },
      {
        "ingredient": "盐",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "香油",
        "amount": "少量",
        "required": false
      }
    ],
    "steps": [
      {
        "order": 1,
        "content": "小葱切葱花，青菜洗净，鸡蛋按需要提前煎好或准备做荷包蛋。",
        "beginner_tip": "青菜提前洗好，煮面时就不会手忙脚乱。",
        "risk_tip": null
      },
      {
        "order": 2,
        "content": "碗中放生抽、盐、葱花和少量香油，准备成基础汤底。",
        "beginner_tip": "汤底先少放盐，面汤冲开后再调整。",
        "risk_tip": null
      },
      {
        "order": 3,
        "content": "锅中烧水，水开后下面条。",
        "beginner_tip": "面条下锅后用筷子拨散，避免粘连。",
        "risk_tip": "沸水煮面时注意蒸汽和溅水烫伤。"
      },
      {
        "order": 4,
        "content": "按面条粗细煮到接近无硬芯。",
        "beginner_tip": "不要煮到完全软烂，热汤里还会继续受热。",
        "risk_tip": null
      },
      {
        "order": 5,
        "content": "加入青菜，烫到变色变软。",
        "beginner_tip": "青菜最后下，颜色更绿，口感更脆。",
        "risk_tip": null
      },
      {
        "order": 6,
        "content": "用热面汤冲开碗底调料，捞入面条、青菜和鸡蛋即可。",
        "beginner_tip": "想要更鲜可加少量白胡椒或醋。",
        "risk_tip": null
      }
    ],
    "common_failures": [
      "面条煮烂",
      "汤底太咸",
      "青菜发黄",
      "面条粘连"
    ],
    "substitutions": {
      "青菜": "可用菠菜、小白菜、生菜或油麦菜。",
      "香油": "可用葱油或不放。"
    },
    "safety_notes": [
      "煮面时注意沸水烫伤。",
      "鸡蛋如做荷包蛋需煮至凝固。"
    ],
    "source_urls": [
      "https://www.xiachufang.com/",
      "https://cook.aiursoft.cn/"
    ]
  },
  {
    "id": 5,
    "name": "酸辣土豆丝",
    "description": "酸辣爽脆的家常素菜，关键是土豆丝冲洗去淀粉并大火快炒。",
    "difficulty": "easy",
    "time_minutes": 20,
    "beginner_friendly": true,
    "cuisine": "家常菜",
    "seasons": [
      "spring",
      "summer",
      "autumn",
      "winter"
    ],
    "ingredients": [
      {
        "ingredient": "土豆",
        "amount": "1个",
        "required": true
      },
      {
        "ingredient": "青椒",
        "amount": "半个",
        "required": false
      },
      {
        "ingredient": "干辣椒",
        "amount": "2-3个",
        "required": false
      },
      {
        "ingredient": "蒜",
        "amount": "2瓣",
        "required": false
      },
      {
        "ingredient": "醋",
        "amount": "1-2勺",
        "required": true
      },
      {
        "ingredient": "盐",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "食用油",
        "amount": "适量",
        "required": true
      }
    ],
    "steps": [
      {
        "order": 1,
        "content": "土豆去皮，先切片再切成尽量均匀的细丝。",
        "beginner_tip": "粗细均匀比切得很细更重要。",
        "risk_tip": "切丝时注意手指和刀具安全。"
      },
      {
        "order": 2,
        "content": "土豆丝用清水反复冲洗，泡水后沥干。",
        "beginner_tip": "冲掉表面淀粉是保持爽脆的关键。",
        "risk_tip": null
      },
      {
        "order": 3,
        "content": "青椒切丝，蒜切末，干辣椒剪段。",
        "beginner_tip": "不吃辣可以去掉干辣椒。",
        "risk_tip": null
      },
      {
        "order": 4,
        "content": "热锅倒油，先爆香干辣椒和蒜。",
        "beginner_tip": "干辣椒容易糊，闻到香味就进入下一步。",
        "risk_tip": null
      },
      {
        "order": 5,
        "content": "下土豆丝大火快炒。",
        "beginner_tip": "土豆丝入锅前尽量沥干，减少溅油。",
        "risk_tip": null
      },
      {
        "order": 6,
        "content": "土豆丝断生后加醋和盐，放青椒丝，快速翻炒出锅。",
        "beginner_tip": "醋早一点加能帮助保持脆感。",
        "risk_tip": null
      }
    ],
    "common_failures": [
      "土豆丝发粘",
      "口感发软",
      "切丝粗细不均",
      "醋味过重"
    ],
    "substitutions": {
      "醋": "可用米醋、陈醋或白醋。",
      "干辣椒": "不吃辣可省略。"
    },
    "safety_notes": [
