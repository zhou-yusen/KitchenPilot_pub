  {
    "id": 6,
    "name": "红烧鱼块",
    "description": "咸鲜下饭的鱼块菜，适合练习鱼块煎定型和中小火焖煮入味。",
    "difficulty": "medium",
    "time_minutes": 35,
    "beginner_friendly": false,
    "cuisine": "家常菜",
    "seasons": [
      "spring",
      "summer",
      "autumn",
      "winter"
    ],
    "ingredients": [
      {
        "ingredient": "草鱼块",
        "amount": "500g",
        "required": true
      },
      {
        "ingredient": "姜",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "蒜",
        "amount": "适量",
        "required": true
      },
      {
        "ingredient": "料酒",
        "amount": "1勺",
        "required": true
      },
      {
        "ingredient": "生抽",
        "amount": "1-2勺",
        "required": true
      },
      {
        "ingredient": "老抽",
        "amount": "少量",
        "required": false
      },
      {
        "ingredient": "豆瓣酱",
        "amount": "1勺",
