APP_NAME=KitchenPilot
APP_ENV=local
API_PREFIX=/api

LLM_PROVIDER=ollama
LLM_TIMEOUT=60

OLLAMA_MODEL=qwen3.5:4b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=qwen3-embedding:0.6b
OLLAMA_DISABLE_THINKING=true
OLLAMA_TRUST_ENV=false

# OpenAI-compatible API. For local Ollama compatibility, use:
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=qwen3.5:4b
# OPENAI_EMBEDDING_MODEL=qwen3-embedding:0.6b
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_DISABLE_THINKING=true
OPENAI_TRUST_ENV=true

SQLITE_DATABASE_URL=sqlite:///./kitchenpilot.db

# Qdrant vector store.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=recipe_chunks
QDRANT_VECTOR_SIZE=1024
QDRANT_TIMEOUT=5
RAG_USE_QDRANT=true

# Legacy embedding aliases still accepted by config.
EMBED_MODEL_TYPE=ollama
EMBED_MODEL_NAME=qwen3-embedding:0.6b
EMBED_API_KEY=ollama
EMBED_BASE_URL=http://localhost:11434
